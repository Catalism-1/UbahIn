{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for the Ubahin shell.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/ubahin-engine",
          "sidecar": true,
          "args": ["--stdio"]
        }
      ]
    }
  ]
}
