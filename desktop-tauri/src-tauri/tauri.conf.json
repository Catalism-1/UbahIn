{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ubahin",
  "version": "0.1.1",
  "identifier": "com.catalism.ubahin",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ubahin",
        "width": 1000,
        "height": 700,
        "minWidth": 760,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/ubahin-engine"],
    "icon": [
      "../../assets/app_icon.ico"
    ]
  }
}
